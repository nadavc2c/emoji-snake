#!/bin/sh
# Auto-refresh the distributables on every push, upload them to the latest GitHub release, AND mirror
# them (epoch-stamped) to the shared Google Drive folder - so the local dist/*.zip, the release
# assets, and the Drive copies always match the pushed code (no need to remember to repackage,
# re-upload, or re-copy). package.ps1 builds two: the Windows jpackage image (no Java needed) and the
# cross-platform zip (Windows/macOS/Linux, needs Java 25). Fully non-blocking: any failure - including
# a missing Drive folder - just warns, and the push still goes through.
#
# Enable on a fresh clone with:  git config core.hooksPath .githooks
echo "pre-push: refreshing dist/*.zip ..."
if command -v pwsh >/dev/null 2>&1; then
  PS=pwsh
else
  PS=powershell.exe
fi
if ! "$PS" -NoProfile -ExecutionPolicy Bypass -File ./package.ps1; then
  echo "pre-push: WARNING - packaging failed; pushing code anyway (run .\\package.ps1 by hand)."
  exit 0
fi

# Keep the latest release's Windows asset in sync (best-effort; skip cleanly if unavailable).
if command -v gh >/dev/null 2>&1; then
  TAG=$(gh release view --json tagName -q .tagName 2>/dev/null)
  if [ -n "$TAG" ]; then
    echo "pre-push: uploading zips to the latest release ($TAG) ..."
    gh release upload "$TAG" "dist/emoji-snake-windows.zip" "dist/emoji-snake-crossplatform.zip" --clobber \
      || echo "pre-push: WARNING - release upload failed (retry: gh release upload $TAG dist/*.zip --clobber)."
  else
    echo "pre-push: no release found; skipping asset upload (make one with: gh release create <tag> dist/emoji-snake-windows.zip)."
  fi
else
  echo "pre-push: gh CLI not found; skipping asset upload."
fi

# Mirror the fresh zips to the shared Google Drive folder, stamped with the build epoch (monotonic,
# unique, and it tells you exactly when the build was made). "Remove then copy" so only the newest
# build lives there. Loud warning but NO failure if the folder isn't mounted.
DRIVE_DIR="/g/My Drive/Shared/emoji snake"
if [ -d "$DRIVE_DIR" ]; then
  VER=$(date +%s)
  echo "pre-push: mirroring zips to Google Drive (build $VER) ..."
  rm -f "$DRIVE_DIR"/emoji-snake-*.zip
  if cp "dist/emoji-snake-windows.zip"       "$DRIVE_DIR/emoji-snake-windows-$VER.zip" \
     && cp "dist/emoji-snake-crossplatform.zip" "$DRIVE_DIR/emoji-snake-crossplatform-$VER.zip"; then
    echo "pre-push: Drive updated -> emoji-snake-{windows,crossplatform}-$VER.zip"
  else
    echo "pre-push: WARNING - copying to Drive failed; push continues."
  fi
else
  echo ""
  echo "  ##################################################################"
  echo "  ##  pre-push WARNING: shared Drive folder NOT found - copy SKIPPED"
  echo "  ##    $DRIVE_DIR"
  echo "  ##  (is Google Drive mounted at G:?)  The push continues anyway.  "
  echo "  ##################################################################"
  echo ""
fi
exit 0
