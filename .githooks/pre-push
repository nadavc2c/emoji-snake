#!/bin/sh
# Auto-refresh the distributables on every push: publish them to a single rolling "latest" GitHub
# release AND mirror them to the shared Google Drive folder - both stamped with ONE git-derived version
# (vMAJOR.MINOR.PATCH), so the app, the release, and the Drive copies always show the same number and
# match the pushed code. package.ps1 builds two: the Windows jpackage image (no Java needed) and the
# cross-platform zip (Windows/macOS/Linux, needs Java 25). Fully non-blocking: any failure - including
# a missing Drive folder - just warns, and the push still goes through.
#
# Enable on a fresh clone with:  git config core.hooksPath .githooks
echo "pre-push: refreshing dist/*.zip ..."
if command -v pwsh >/dev/null 2>&1; then
  PS=pwsh
else
  PS=powershell.exe
fi
if ! "$PS" -NoProfile -ExecutionPolicy Bypass -File ./package.ps1; then
  echo "pre-push: WARNING - packaging failed; pushing code anyway (run .\\package.ps1 by hand)."
  exit 0
fi

# Single source of truth for the version (matches build.gradle's gitVersion): vMAJOR.MINOR.PATCH, with
# MAJOR.MINOR from the latest vX.Y tag and PATCH = commits since it - so it advances on every push
# (v1.3 -> v1.3.0, then v1.3.1, ...). One number for the release AND the Drive filenames.
RAW=$(git describe --tags --match 'v[0-9]*' --always 2>/dev/null)
V=${RAW#v}
case "$V" in
  *-*-g*) base=${V%%-*}; rest=${V#*-}; VER="v$base.${rest%%-*}" ;;  # v1.3-10-gsha -> v1.3.10
  *[!0-9.]*) VER="v0.0.0" ;;                                        # bare commit hash / no tags
  *.*) VER="v$V.0" ;;                                               # exact tag v1.3 -> v1.3.0
  *) VER="v0.0.0" ;;
esac

# Publish the freshest build to a single rolling "latest" release. Delete + recreate it each push so
# its tag, timestamp, title, and assets ALL reflect this exact build - no drift (no more "v1.3 released
# 4h ago, assets 6 min ago"). The hand-cut vX.Y releases stay as milestone history. All via gh (the
# API), so nothing does a local `git push` that would re-trigger this hook.
if command -v gh >/dev/null 2>&1; then
  SHA=$(git rev-parse HEAD)
  NOTES=$(printf '%s\n\n**Downloads**\n- `emoji-snake-windows.zip` - Windows, no Java needed: unzip, run `Emoji Snake\\Emoji Snake.exe`.\n- `emoji-snake-crossplatform.zip` - Windows/macOS/Linux, needs Java 25: unzip, run `bin/emoji-snake` (or `bin\\emoji-snake.bat`).\n\n_This release always tracks the newest push; the numbered vX.Y releases are milestones._' "The latest Emoji Snake build ($VER).")
  echo "pre-push: publishing rolling 'latest' release ($VER) ..."
  gh release delete latest --yes --cleanup-tag >/dev/null 2>&1   # drop the previous rolling release + its tag (ok if absent)
  if gh release create latest "dist/emoji-snake-windows.zip" "dist/emoji-snake-crossplatform.zip" \
       --title "Emoji Snake $VER" --notes "$NOTES" --latest --target "$SHA" >/dev/null 2>&1; then
    echo "pre-push: 'latest' release updated -> $VER"
  else
    echo "pre-push: WARNING - could not publish the 'latest' release."
  fi
else
  echo "pre-push: gh CLI not found; skipping the 'latest' release."
fi

# Mirror the fresh zips to the shared Google Drive folder, named with the same $VER (vMAJOR.MINOR.PATCH).
# "Remove then copy" so only the newest build lives there. Loud warning but NO failure if unmounted.
DRIVE_DIR="/g/My Drive/Shared/emoji snake"
if [ -d "$DRIVE_DIR" ]; then
  echo "pre-push: mirroring zips to Google Drive (build $VER) ..."
  rm -f "$DRIVE_DIR"/emoji-snake-*.zip
  if cp "dist/emoji-snake-windows.zip"       "$DRIVE_DIR/emoji-snake-windows-$VER.zip" \
     && cp "dist/emoji-snake-crossplatform.zip" "$DRIVE_DIR/emoji-snake-crossplatform-$VER.zip"; then
    echo "pre-push: Drive updated -> emoji-snake-{windows,crossplatform}-$VER.zip"
  else
    echo "pre-push: WARNING - copying to Drive failed; push continues."
  fi
else
  echo ""
  echo "  ##################################################################"
  echo "  ##  pre-push WARNING: shared Drive folder NOT found - copy SKIPPED"
  echo "  ##    $DRIVE_DIR"
  echo "  ##  (is Google Drive mounted at G:?)  The push continues anyway.  "
  echo "  ##################################################################"
  echo ""
fi
exit 0
